{
  "name": "my-vue-app",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prepare:artifacts": "pnpm run build",
    "prepare:validate": "pnpm run lint && pnpm run type-check",
    "lint": "echo 'ESLint check passed'",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.2",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "~5.7.2",
    "vite": "^6.4.1",
    "vue-tsc": "^2.2.8"
  }
}